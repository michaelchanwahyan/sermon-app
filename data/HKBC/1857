						if (scriptureHtml){
							scriptureContainer.html(scriptureHtml);
						}
					}
				}
			}
		}).always(function(){
			xhr = null;
			hideLoadingSpinner();
		});
	}
	
	function closeScripture(){
		var isMobile = $(window).width() < 992;
		if ($("#section-scripture").hasClass("active")){
			$("#section-scripture .magnifier-content").html("");
